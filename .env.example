# Copy this file to ".env" and fill in your values.
# The server loads it automatically (via dotenv) from its working directory.

# OpenRouteService API key — enables real drive-time isochrones and travel
# times. Without it the app falls back to straight-line circle/estimates.
# Get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Port the server listens on
PORT=3080

# Base URL of the ORS API. Leave blank to use the public service. To use a
# self-hosted instance (no rate limits), point this at it — include the /ors
# path, no trailing slash, e.g.:
#   ORS_BASE_URL=http://localhost:8082/ors
# When self-hosting, set ORS_API_KEY to any non-empty value (self-hosted ORS
# ignores auth). The app sends the full requested drive time straight to ORS,
# so the only range limit is the one your ORS instance enforces:
#
#   The public ORS API caps isochrones at 3600s (60 min). A self-hosted
#   instance has its OWN cap, also 3600s by default. Raise the isochrones
#   endpoint's "maximum_range_time" (seconds) in your ors-config and restart
#   the ORS container — e.g. for a 90-min limit:
#       ors.endpoints.isochrones.maximum_range_time: 5400
#   (Newer ORS versions take this as a per-profile list; check your config
#   file's existing format. The matching env-var override is
#   ORS_ENDPOINTS_ISOCHRONES_MAXIMUM_RANGE_TIME=5400.)
#   If a requested range exceeds the cap, ORS rejects it and the app falls
#   back to drawing a plain circle (the reason is logged to the app console).
ORS_BASE_URL=

# Splash screen: set to false to skip the intro screen
SHOW_SPLASH=true

# Splash color preset: red | mgs | blue
SPLASH_COLOR=red
