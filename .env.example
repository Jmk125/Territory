# Copy this file to ".env" and fill in your values.
# The server loads it automatically (via dotenv) from its working directory.

# OpenRouteService API key — enables real drive-time isochrones and travel
# times. Without it the app falls back to straight-line circle/estimates.
# Get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Port the server listens on
PORT=3080

# ── ORS data source ──────────────────────────────────────────────────────
# The data source (public API vs. a self-hosted ORS server) and the drive-time
# limit are now configurable at runtime from the app: Configure tab → ⚙ gear.
# That choice is saved to data/settings.db and survives restarts.
#
# The two vars below are only SEED DEFAULTS used the first time the app runs
# (before anything is saved from the UI), so existing setups keep working:
#
#   ORS_BASE_URL       — a self-hosted ORS base URL (include the /ors path),
#                        e.g. http://localhost:8082/ors. Leave blank for the
#                        public API. When self-hosting, set ORS_API_KEY to any
#                        non-empty value (self-hosted ORS ignores auth).
#   ORS_MAX_RANGE_SEC  — seed for the drive-time limit, in seconds (e.g. 5400
#                        for 90 min). Ignored in public-API mode (hard cap 60).
#
# Range limits beyond 60 min require a self-hosted ORS whose own isochrone cap
# is raised: set the isochrones endpoint's "maximum_range_time" (seconds) in
# ors-config and restart ORS — e.g. for 90 min:
#     ors.endpoints.isochrones.maximum_range_time: 5400
# (Newer ORS versions take this as a per-profile list; match your config file's
# format. Env-var override: ORS_ENDPOINTS_ISOCHRONES_MAXIMUM_RANGE_TIME=5400.)
# If a requested range exceeds the source's cap, the app approximates it by
# padding the capped isochrone outward (and labels that coverage as "approx").
ORS_BASE_URL=
ORS_MAX_RANGE_SEC=

# Splash screen: set to false to skip the intro screen
SHOW_SPLASH=true

# Splash color preset: red | mgs | blue
SPLASH_COLOR=red
